# Generate both SPK and JWT_SECRET with: node scripts/gen-spk.js

# Ed25519 server signing key (128 hex chars = 64 bytes)
SPK=

# HMAC key for JWT signing — must be separate from SPK (64 hex chars = 32 bytes)
JWT_SECRET=

# CANARY=true

# Database engine: sqlite3 (default) | sqlite3mem (in-memory, for testing)
DB_TYPE=sqlite3

# HTTP listen port (default: 16777). Change if running outside Docker.
# API_PORT=16777

# Optional comma-separated CORS origin allowlist (e.g. https://app.vex.wtf,https://vex.wtf).
# If unset, Spire reflects the browser's Origin (any host) so self-hosted and
# third-party clients work without extra config. Set this to lock down which
# frontends may use browser credentials against your instance.
# CORS_ORIGINS=

# Local stress only (`npm run stress:local`). When set, requests that send header
# `X-Spire-Stress-Bypass: <same value>` skip Spire's in-process rate limiters.
# Never set this in production. Match the same variable on the stress client env.
# SPIRE_STRESS_BYPASS_KEY=
# SPIRE_STRESS_HOST=127.0.0.1:8080
# SPIRE_STRESS_CONCURRENCY=200
# SPIRE_STRESS_ROUNDS=10
# SPIRE_STRESS_SCENARIO=mixed
#   (mixed | whoami | servers — see scripts/stress/spire-stress.ts)
# SPIRE_STRESS_CLIENTS=1
# SPIRE_STRESS_WS=0
# SPIRE_STRESS_USERNAME=
# SPIRE_STRESS_PASSWORD=
